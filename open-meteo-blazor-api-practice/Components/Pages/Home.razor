@page "/"
@rendermode InteractiveServer
@using System.Net.Http
@inject IHttpClientFactory ClientFactory

<PageTitle>Evanston Weather Forecast</PageTitle>

<h3>Evanston 7-Day Temperature Trend</h3>

<div style="width: 100%; height: 500px; background-color: #1e1e1e; padding: 10px; border-radius: 8px;">
    @if (_yData.Length > 0)
    {
        <SciChartSurface HeightAspect="2" WidthAspect="3">
            <XAxes>
                <NumericAxis AxisTitle="Hours (from now)" />
            </XAxes>
            <YAxes>
                <NumericAxis AxisTitle="Temperature (°C)" />
            </YAxes>
            
            <FastLineRenderableSeries Stroke="#50C878" StrokeThickness="3" SeriesName="Temp">
                <XyDataSeries XValues="@_xData" YValues="@_yData" />
            </FastLineRenderableSeries>

            <MouseWheelZoomModifier />
            <ZoomPanModifier />
            <ZoomExtentsModifier />
        </SciChartSurface>
    }
    else
    {
        <p style="color: white;">Fetching weather data from Open-Meteo...</p>
    }
</div>

@code {
    private double[] _xData = Array.Empty<double>();
    private double[] _yData = Array.Empty<double>();

    protected override async Task OnInitializedAsync()
    {
        var weatherClient = ClientFactory.CreateClient("OpenMeteo");
        var endpoint = "forecast?latitude=41.2683&longitude=-110.9632&hourly=temperature_2m&past_days=0&forecast_days=7";
        var response = await weatherClient.GetFromJsonAsync<WeatherResponse>(endpoint);

        if (response?.Hourly?.Temperature2m != null)
        {
            _yData = response.Hourly.Temperature2m;
            
            // Create a simple X-axis array (0, 1, 2, 3...) to match the hours
            _xData = Enumerable.Range(0, _yData.Length).Select(i => (double)i).ToArray();
        }
    }

    // C# classes to parse the JSON from Open-Meteo
    public class WeatherResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("hourly")]
        public HourlyData Hourly { get; set; }
    }

    public class HourlyData
    {
        [System.Text.Json.Serialization.JsonPropertyName("temperature_2m")]
        public double[] Temperature2m { get; set; }
    }
}